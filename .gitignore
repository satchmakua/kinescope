# --- Base ignores (stack-agnostic) ---

# Secrets / local env — never commit real ones (see .env.example)
.env
.env.*
!.env.example
*.local

# AI assistant build instructions — kept local, never committed
CLAUDE.md
CLAUDE.local.md

# Editor / OS cruft
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.DS_Store
Thumbs.db
*.log

# Generic build / cache output
dist/
build/
out/
coverage/
.cache/
tmp/
*.tmp

# --- Stack-specific (Python) ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Eidetic trace stores (recorded runs — local artifacts, not source)
.eidetic/
